# Server-side environment variables
# DATABASE_URL=your-database-url
# OPENAI_API_KEY=your-openai-key

# Client-side environment variables (must start with NEXT_PUBLIC_)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend deployment variables
# DECISIONOS_SECRET_KEY=replace-with-strong-secret
# DECISIONOS_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# DECISIONOS_DB_PATH=/data/decisionos.db
# LLM_MODE=mock
# DECISIONOS_AUTH_DISABLED=0
# DECISIONOS_AUTH_SESSION_TTL_SECONDS=43200

# REQUIRED: Admin user credentials (no defaults, must be set)
DECISIONOS_SEED_ADMIN_USERNAME=admin
DECISIONOS_SEED_ADMIN_PASSWORD=change-me-to-strong-password

# Test user credentials (optional, has defaults)
# DECISIONOS_SEED_TEST_USERNAME=test
# DECISIONOS_SEED_TEST_PASSWORD=test
